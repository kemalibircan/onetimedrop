{
  "expo": {
    "name": "FileFast",
    "slug": "filefast-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7EF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.onetimedrop.filefast",
      "infoPlist": {
        "NSCameraUsageDescription": "Required to scan QR codes for desktop sessions",
        "NSPhotoLibraryUsageDescription": "Access photos to send files to desktop"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF7EF"
      },
      "package": "com.onetimedrop.filefast",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      "expo-font",
      "expo-document-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FileFast to access your camera to scan QR codes."
        }
      ],
      "expo-localization"
    ]
  }
}
